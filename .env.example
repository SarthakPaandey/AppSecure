# Embedding provider (ModelScope OpenAI-compatible API)
EMBEDDING_BASE_URL=https://api-inference.modelscope.ai/v1
MODELSCOPE_API_KEY=
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B

# Chat / planner / synthesis — Cerebras Gemma 4 (fast)
LLM_BASE_URL=https://api.cerebras.ai/v1
LLM_API_KEY=
LLM_MODEL=gemma-4-31b
LLM_FALLBACK_MODELS=
LLM_REASONING_EFFORT=none
LLM_MAX_TOKENS=1200

# V2 pipeline defaults (essay-aligned)
USE_SEMANTIC_PLANNER=true
PLANNER_MODEL=gemma-4-31b
USE_DYNAMIC_SYNTHESIS=true
# Dedicated scope LLM off by default (rules + planner in_scope)
USE_LLM_SCOPE_GATE=false
# Multi-round tool agent off by default (not the main path)
USE_TOOL_AGENT=false
TOOL_LLM_MODEL=gemma-4-31b
TOOL_LLM_FALLBACK_MODELS=
TOOL_AGENT_MAX_ROUNDS=3
CITATION_GATE_STRICT=true
CITATION_REGEN_ON_FAIL=true

# Storage
DATA_DIR=./data
SQLITE_PATH=./data/app.db
CHROMA_PATH=./data/chroma
KNOWLEDGE_DIR=./data/knowledge

# Retrieval / rerank (RRF light by default; CE optional)
RERANK_MODE=light
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
CROSS_ENCODER_ENABLED=false

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
